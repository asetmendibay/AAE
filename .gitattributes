# Set default behavior to automatically normalize line endings
* text=auto

# Enforce LF line endings for all text files
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Explicitly declare binary files that should not be normalized
*.png -text
*.jpg -text
*.jpeg -text
*.gif -text
*.ico -text
